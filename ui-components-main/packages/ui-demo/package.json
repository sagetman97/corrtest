{
  "name": "@pollyex/ui-demo",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build && vue-tsc --noEmit",
    "preview": "vite preview",
    "copy:index": "if [ -n \"$DEMO_PATH\" ]; then cp ../../docs/$DEMO_PATH/index.html ../../docs/$DEMO_PATH/404.html; else cp dist/index.html dist/404.html; fi",
    "dev": "vite",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0"
  },
  "peerDependencies": {
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@pollyex/eslint-config": "0.0.10",
    "@rushstack/eslint-patch": "^1.3.3",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^8.51.0",
    "prettier": "^3.5.3",
    "string-ts": "^2.0.0",
    "typescript": "5.8.2",
    "valibot": "1.0.0-beta.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-svg-loader": "^5.1.0",
    "vue-router": "^5.0.0"
  },
  "dependencies": {
    "shiki": "^4.0.2"
  }
}
